#!/usr/bin/env php
<?php

declare(strict_types=1);

use Ekvedaras\SpaceSim\World;
use NunoMaduro\Collision\Provider as CollisonProvider;

use function Laravel\Prompts\confirm;
use function Laravel\Prompts\select;

require __DIR__ . '/../vendor/autoload.php';

(new CollisonProvider)->register();

$world = new World(
  doctrine: new \Ekvedaras\SpaceSim\Doctrines\PlanetaryIndustry(),
  energy: 50,
);

$world->print();

for ($tick = 1; $tick <= 100; $tick++) {
  echo "Tick {$tick}\n";
  $world->tick();
  echo $world->print();

  if ($tick % 5 === 0) {
    $world->allowChangingDoctrine = true;
  }

  $actions = $world->availableActions();
  $choice = select('What to do next?', $actions);

  $actions[$choice]->execute($world);
}