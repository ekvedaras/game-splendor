#!/usr/bin/env php
<?php

declare(strict_types=1);

use Ekvedaras\SpaceSim\Actions\Action;
use Ekvedaras\SpaceSim\Deck\ClosedDeck;
use Ekvedaras\SpaceSim\Game;
use Ekvedaras\SpaceSim\Player;
use NunoMaduro\Collision\Provider as CollisonProvider;

use function Laravel\Prompts\select;

require __DIR__ . '/../vendor/autoload.php';

(new CollisonProvider)->register();

$game = new Game(
    players: [
        $player1 = new Player('Player 1'),
        $player2 = new Player('Player 2'),
    ],
    firstLevelDeck: ClosedDeck::forFirstLevel()->shuffle(),
    secondLevelDeck: ClosedDeck::forSecondLevel()->shuffle(),
    thirdLevelDeck: ClosedDeck::forThirdLevel()->shuffle(),
);

for (;;) {
    $game->print();
    echo "\n-----------------------------------------------\n";

    for (;;) {
        $action = select('Action', $game->actions());

        /** @var Action $action */
        $action = new $action();
        $input = $action->input($game);
        if ($action->allowed($game, $game->currentPlayer, $input)) {
            $action->perform($game, $game->currentPlayer, $input);
            break;
        }

        echo "Ah ah\n";
    }
}


