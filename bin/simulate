#!/usr/bin/env php
<?php

declare(strict_types=1);

use Ekvedaras\SpaceSim\Deck\ClosedDeck;
use Ekvedaras\SpaceSim\Game;
use Ekvedaras\SpaceSim\Player;
use NunoMaduro\Collision\Provider as CollisonProvider;

require __DIR__ . '/../vendor/autoload.php';

(new CollisonProvider)->register();

$game = new Game(
    players: [
        $player1 = new Player('Player 1'),
        $player2 = new Player('Player 2'),
    ],
    firstLevelDeck: ClosedDeck::forFirstLevel()->shuffle(),
    secondLevelDeck: ClosedDeck::forSecondLevel()->shuffle(),
    thirdLevelDeck: ClosedDeck::forThirdLevel()->shuffle(),
);

$game->print();
echo "\n-----------------------------------------------\n";

$player1
    ->takeOneResource(from: $game->resourcesOnTheTable->redStack)
    ->takeOneResource(from: $game->resourcesOnTheTable->greenStack)
    ->takeOneResource(from: $game->resourcesOnTheTable->blueStack);

$game->print();
echo "\n-----------------------------------------------\n";

$player2->takeTwoResources(from: $game->resourcesOnTheTable->blackStack);

$game->print();
echo "\n-----------------------------------------------\n";

$player1->takeCard(1, from: $game->firstLevelOpenCards);

$game->print();
